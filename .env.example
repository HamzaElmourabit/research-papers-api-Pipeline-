# Configuration for ArXiv Pipeline

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/arxiv_pipeline.log

# ArXiv API
ARXIV_BATCH_SIZE=10
ARXIV_DOMAINS=cs.AI,cs.LG,cs.CV,cs.CL,stat.ML

# Cassandra
CASSANDRA_HOST=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=arxiv

# Data Quality Thresholds
QUALITY_CRITICAL_THRESHOLD=80
QUALITY_WARNING_THRESHOLD=95
QUALITY_DUPLICATE_THRESHOLD=5

# Retry Configuration
RETRY_MAX_RETRIES=3
RETRY_INITIAL_DELAY=1
RETRY_MAX_DELAY=60

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60

# Environment
ENVIRONMENT=development
DEBUG=false
